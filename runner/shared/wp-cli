runner_wp_cli() {
    if command -v wp >/dev/null 2>&1; then
        echo "wp"
        return 0
    fi

    local candidate
    for candidate in "/usr/local/bin/wp" "$HOME/bin/wp" "/opt/wp-cli/wp"; do
        if [ -x "$candidate" ]; then
            echo "$candidate"
            return 0
        fi
    done

    runner_error "WP-CLI is required but was not found."
    return 1
}
